# Docker Compose uses `.env` by default. If you prefer `.env.local`, run
# `docker compose --env-file .env.local ...` so compose interpolation can see
# these values too.

# Docker / Compose ports
#
# Port the Next.js app listens on inside the container.
APP_PORT=3000

# Optional host-side published ports.
APP_HOST_PORT=3000
POCKETBASE_HOST_PORT=8090

# Optional built-in TLS proxy via `docker compose --profile tls up`.
# Set APP_DOMAIN to a public DNS name pointing at this host to let Caddy obtain
# and renew a certificate automatically. Leave blank if you plan to use your own
# reverse proxy instead.
APP_DOMAIN=
HTTP_PORT=80
HTTPS_PORT=443

# PocketBase / app wiring
#
# URL the Next.js server uses to talk to PocketBase.
# - Local dev: usually http://127.0.0.1:8090
# - Docker Compose: usually http://pocketbase:8090
POCKETBASE_URL=http://127.0.0.1:8090

# URL the browser uses to reach PocketBase directly.
# Used for browser-side PocketBase access such as realtime subscriptions.
# In production this should be the public, browser-reachable URL for PB
# (often behind the same reverse proxy/domain as the app).
# If you use the optional built-in TLS proxy, set this to
# `https://<APP_DOMAIN>/pb`.
NEXT_PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090

# PocketBase superuser credentials.
# Required for:
# - the app's server-side admin PocketBase client
# - `pnpm pb:bootstrap`
# Set both before first boot/deploy.
POCKETBASE_SUPERUSER_EMAIL=dev@stowage.local
POCKETBASE_SUPERUSER_PASSWORD=

# Optional global attachment storage quota, in gigabytes.
# Examples: 0.5, 2, 10
# Behavior:
# - Leave blank to disable the quota entirely
# - Applies to both asset attachments and service-record attachments
# - Uses base-2 GB (1 GB = 1024 * 1024 * 1024 bytes)
# - Failed attachment uploads do not count toward the used total
STORAGE_LIMIT_GB=

# Optional public app base URL.
# Used when generating URLs embedded in labels / QR codes.
# Example local value: http://localhost:3000
# Example production value: https://assets.example.com
# If you use the optional built-in TLS proxy, set this to
# `https://<APP_DOMAIN>`.
# Leave blank if you do not want a label URL base configured.
SITE_URL=http://localhost:3000

# E2E tests
#
# Optional credentials for a real user/admin on the target PocketBase instance.
# When these are unset, Playwright still runs the unauthenticated redirect
# coverage, but it skips the authenticated CRUD / workflow scenarios.
E2E_AUTH_EMAIL=
E2E_AUTH_PASSWORD=
