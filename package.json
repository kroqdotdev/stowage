    "@types/react": "^19",
    "@types/react-dom": "^19",
    "convex-test": "^0.0.41",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^28.1.0",
